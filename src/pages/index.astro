    const buttons = document.querySelectorAll(".tool-btn");
    const list = document.getElementById("tool-list") as HTMLElement;
    const name = document.getElementById("name") as HTMLElement;

    let current: ToolCategory = "web";
    const colors = ["text-blue-700", "text-orange-700", "text-pink-700"];
    const colorindex = Math.floor(Math.random() * colors.length);
    const randomcolor = colors[colorindex];

    function updateClock() {
        const clockelement = document.getElementById("clock");
        if (clockelement) {
            const now = new Date();
            clockelement.textContent = now.toLocaleTimeString();
        };
    };

    function updateDate() {
        const dateelement = document.getElementById("date")
        if (dateelement) {
            const nowdate = new Date();
            dateelement.textContent = nowdate.toLocaleDateString();
        };
    };

    function colorchange() {
        name.classList.add(`${randomcolor}`)
    };

    function render() {
        list.innerHTML = data[current]
        .map((item) => `
        <li>
            <a href="${item.href}">
                <div class="flex flex-col text-center ${item.color} hover:-translate-y-1 transition-transform transition-colors select-none">
                    ${item.svg}
                    <p>${item.name}</p>
                </div>
            </a>
        </li>
        
        `)
        .join("")
        buttons.forEach(element => { 
            element.classList.remove("active")    
        });
        const currentbutton = document.getElementById(`${current}`)!;
        currentbutton.classList.add("active")
    }

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            current = btn.dataset.type;
            render();
        })     
    });
</script>