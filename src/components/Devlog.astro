---
import { type CollectionEntry } from "astro:content";
import { render } from "astro:content"

type Props = {
    devlog: CollectionEntry<"devlogs">;
}

const { devlog } = Astro.props
const { Content } = await render(devlog);

---

<div class="border-2 border-zinc-400 rounded-2xl bg-gray-900 px-3">
    <a
        href={`/Projects/${devlog.data.link}`}
        aria-label={`Read more about ${devlog.data.title}`}
    >
        <img
                src={devlog.data.image}
                alt={devlog.data.title}
                class="rounded-2xl shadow-2xl border-2 border-gray-950 mb-6 mt-2 h-auto max-h-96 w-full object-contain"/>
    </a>

    <a
        href={`/Projects/${devlog.data.link}`}
        class="text-4xl text-zinc-200 mb-4 font-semibold inline-block hover:underline"
    >
        {devlog.data.title}
    </a>

    <p class="text-zinc-400 text-2xl mb-9 line-clamp-2">
        {devlog.data.project}
    </p>

    <p class="text-zinc-400 text-2xl mb-9 line-clamp-2">
        {devlog.body}
    </p>

        <span class="text-zinc-400 text-xl">
            {devlog.data.date}
        </span>
    </div>
</div>