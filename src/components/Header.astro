---
import "../styles/global.css";
const currentPath = Astro.url.pathname;
---
<header class="w-full bg-[#12151a] backdrop-blur border-b">
    <div class="max-w-7xl w-full mx-auto flex justify-between items-center px-24 py-4 max-sm:px-5 max-sm:py-10 ">
        <a href="/" class="flex items-center gap-x-4">
            <img
            src="/portfolioicongray.svg"
            width={160}
            height={160}
            alt="favicon"
            class = "rounded-2xl aspect-thumbnail object-cover"
        />
        </a>
        
        <ul class="flex gap-x-8">
            <li><a href="/" class={`nav-link font-bold ${currentPath === "/" ? "active" : ""}`}>Home</a></li>
            <li><a href="/projects" class={`nav-link font-bold ${currentPath.startsWith("/projects") ? "active" : ""}`}>Projects</a></li>
            <li><a href="/about" class={`nav-link font-bold ${currentPath.startsWith("/about") ? "active" : ""}`}>About</a></li>
        </ul>
    </div>
</header>